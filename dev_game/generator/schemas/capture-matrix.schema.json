{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coreline-ai.local/dev-game/capture-matrix.schema.json",
  "title": "dev_game captured-state QA matrix",
  "type": "object",
  "required": ["schemaVersion", "viewports", "states"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "viewports": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["width", "height", "dpr"],
        "properties": {
          "width": { "type": "integer", "minimum": 320 },
          "height": { "type": "integer", "minimum": 568 },
          "dpr": { "type": "number", "minimum": 1, "maximum": 4 }
        }
      }
    },
    "states": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "expectedScene", "requiredIds"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "expectedScene": { "type": "string", "minLength": 1 },
          "requiredIds": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "terminal": { "enum": ["none", "win", "loss"] },
          "assertions": { "type": "object" },
          "capture": { "type": "boolean" }
        }
      }
    }
  }
}
