{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coreline-ai.local/dev-game/game-spec.v2.schema.json",
  "title": "dev_game custom-loop production game spec v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "game",
    "canvas",
    "buildDecision",
    "implementationStatus",
    "runtimeConfig",
    "rules",
    "requiredAssetRoles",
    "captureMatrix",
    "audio",
    "ui",
    "performance"
  ],
  "properties": {
    "schemaVersion": { "const": "2.0.0" },
    "game": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "orientation", "target"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "orientation": { "enum": ["portrait", "landscape"] },
        "target": { "enum": ["mobile-web", "web"] }
      }
    },
    "canvas": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height", "backgroundColor", "scaleMode"],
      "properties": {
        "width": { "type": "integer", "minimum": 320 },
        "height": { "type": "integer", "minimum": 568 },
        "backgroundColor": { "type": "string", "pattern": "^#([0-9a-fA-F]{3}|[0-9a-fA-F]{6})$" },
        "scaleMode": { "enum": ["fit", "cover"] }
      }
    },
    "buildDecision": { "enum": ["archetype-start", "hybrid", "custom-loop"] },
    "implementationStatus": { "enum": ["foundation", "implemented", "production-demo"] },
    "runtimeConfig": { "type": "string", "minLength": 1 },
    "rules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["durationSeconds", "goal", "progressMetric", "failConditions", "commands"],
      "properties": {
        "durationSeconds": { "type": "number", "exclusiveMinimum": 0 },
        "goal": { "type": "string", "minLength": 1 },
        "progressMetric": { "type": "string", "minLength": 1 },
        "requiredObjectives": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "failConditions": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "label", "input"],
            "properties": {
              "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
              "label": { "type": "string", "minLength": 1 },
              "input": { "type": "string", "minLength": 1 },
              "costs": { "type": "object" }
            }
          }
        }
      }
    },
    "requiredAssetRoles": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }
    },
    "captureMatrix": { "type": "string", "minLength": 1 },
    "audio": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "sfx", "music"],
      "properties": {
        "enabled": { "type": "boolean" },
        "sfx": { "type": "object" },
        "music": { "type": "object" }
      }
    },
    "ui": {
      "type": "object",
      "additionalProperties": false,
      "required": ["showPause", "showProgressMetric", "helpRequired"],
      "properties": {
        "showPause": { "type": "boolean" },
        "showProgressMetric": { "type": "boolean" },
        "helpRequired": { "type": "boolean" }
      }
    },
    "performance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["targetFps", "pauseWhenHidden", "maxTargetDpr"],
      "properties": {
        "targetFps": { "enum": [30, 60] },
        "pauseWhenHidden": { "const": true },
        "maxTargetDpr": { "type": "number", "minimum": 1, "maximum": 4 }
      }
    }
  }
}
