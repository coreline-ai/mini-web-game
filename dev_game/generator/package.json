{
  "name": "dev-game-factory",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Scaffold and QA mobile portrait Phaser/Vite games as high-quality first production-grade demos.",
  "bin": {
    "dev-game": "src/cli.mjs"
  },
  "scripts": {
    "make": "node scripts/make-game.mjs",
    "validate": "node src/cli.mjs --validate-only --spec examples/poop-dodge.spec.json",
    "dry-run": "node src/cli.mjs --dry-run --spec examples/poop-dodge.spec.json --out ../generated/poop-dodge-demo",
    "smoke": "node scripts/smoke-generate.mjs",
    "productionize": "node scripts/productionize.mjs",
    "imagegen": "node scripts/codex-imagegen.mjs",
    "asset-qa": "node scripts/asset-qa.mjs",
    "browser-smoke": "node scripts/browser-smoke.mjs",
    "qa": "npm run validate && npm run smoke && npm run asset-qa && npm run browser-smoke",
    "production-demo-qa": "node scripts/production-demo-qa.mjs",
    "visual-layout-qa": "node scripts/visual-layout-qa.mjs",
    "image-quality-qa": "node scripts/image-quality-qa.mjs",
    "production-gate": "node scripts/production-gate.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "playwright": "^1.61.1"
  }
}
