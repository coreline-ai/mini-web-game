{
  "name": "dev-game-factory",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Scaffold and QA mobile portrait Phaser/Vite games as high-quality first production-grade demos.",
  "bin": {
    "dev-game": "src/cli.mjs"
  },
  "scripts": {
    "make": "node scripts/make-game.mjs",
    "validate": "node src/cli.mjs --validate-only --spec examples/poop-dodge.spec.json",
    "dry-run": "node src/cli.mjs --dry-run --spec examples/poop-dodge.spec.json --out ../generated/poop-dodge-demo",
    "smoke": "node scripts/smoke-generate.mjs",
    "productionize": "node scripts/productionize.mjs",
    "imagegen": "node scripts/codex-imagegen.mjs",
    "asset-qa": "node scripts/asset-qa.mjs",
    "browser-smoke": "node scripts/browser-smoke.mjs",
    "runtime-asset-delivery-test": "node scripts/runtime-asset-delivery-test.mjs",
    "dist-runtime-qa": "node scripts/dist-runtime-qa.mjs",
    "qa": "npm run validate && npm run smoke && npm run runtime-asset-delivery-test && npm run asset-qa && npm run browser-smoke",
    "production-demo-qa": "node scripts/production-demo-qa.mjs",
    "visual-layout-qa": "node scripts/visual-layout-qa.mjs",
    "scene-composite-qa": "node scripts/scene-composite-qa.mjs",
    "image-quality-qa": "node scripts/image-quality-qa.mjs",
    "hq-screen-quality-qa": "node scripts/hq-screen-quality-qa.mjs",
    "captured-state-qa": "node scripts/captured-state-qa.mjs",
    "first-play-clarity-qa": "node scripts/first-play-clarity-qa.mjs",
    "input-hostility-qa": "node scripts/input-hostility-qa.mjs",
    "session-continuity-qa": "node scripts/session-continuity-qa.mjs",
    "docs-runtime-sync-qa": "node scripts/docs-runtime-sync-qa.mjs",
    "qa-session-report": "node scripts/qa-session-report.mjs",
    "migrate-spec-v2": "node scripts/migrate-spec-v2.mjs",
    "production-gate": "node scripts/production-gate.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "playwright": "^1.61.1"
  }
}
