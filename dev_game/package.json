{
  "name": "dev-game-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "factory:validate": "node generator/src/cli.mjs --validate-only --spec generator/examples/poop-dodge.spec.json",
    "factory:dry-run": "node generator/src/cli.mjs --dry-run --spec generator/examples/poop-dodge.spec.json --out generated/poop-dodge-demo",
    "factory:smoke": "node generator/scripts/smoke-generate.mjs",
    "factory:asset-qa": "node generator/scripts/asset-qa.mjs",
    "factory:browser-smoke": "node generator/scripts/browser-smoke.mjs",
    "factory:qa": "npm run factory:validate && npm run factory:smoke && npm run factory:asset-qa && npm run factory:browser-smoke"
  },
  "devDependencies": {
    "playwright": "^1.61.1"
  },
  "engines": {
    "node": ">=18"
  }
}
