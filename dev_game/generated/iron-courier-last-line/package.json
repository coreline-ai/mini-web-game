{
  "name": "iron-courier-last-line",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "play": "vite --host 127.0.0.1 --port 5195 --open",
    "play:production": "npm run build && vite preview --host 127.0.0.1 --port 5195 --strictPort --open",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "assets:repack:phase6": "python3 scripts/process-ui-props-assets.py",
    "assets:manifest:phase6": "python3 scripts/register-phase6-assets.py",
    "assets:normalize:projectiles": "python3 scripts/normalize-projectile-assets.py",
    "assets:zones": "python3 scripts/process-zone-layer-assets.py",
    "assets:hud-icons": "python3 scripts/process-hud-icon-assets.py",
    "assets:projectile-variants": "python3 scripts/create-projectile-variants.py",
    "assets:player-extensions": "python3 scripts/process-player-extensions.py",
    "assets:player-fire-polish": "python3 scripts/create-player-shoot-polished.py",
    "assets:player-identity-repair": "python3 scripts/repair-player-movement-identity.py",
    "assets:rescue-motion-polish": "python3 scripts/normalize-rescue-motion-assets.py",
    "assets:enemy-extensions": "python3 scripts/process-enemy-extensions.py",
    "assets:transport-extensions": "python3 scripts/process-transport-extensions.py",
    "assets:vfx-variants": "python3 scripts/process-vfx-variants.py",
    "assets:optimize:mobile": "python3 scripts/optimize-runtime-atlases.py",
    "assets:prune:unused": "python3 scripts/prune-unused-runtime-assets.py",
    "assets:metadata:finalize": "python3 scripts/finalize-animation-metadata.py",
    "assets:machines:512": "python3 scripts/restore-large-machine-atlases.py",
    "qa:asset-coverage": "node scripts/asset-coverage-qa.mjs",
    "qa:asset-coverage:baseline": "node scripts/asset-coverage-qa.mjs --baseline",
    "qa:runtime-art": "node scripts/runtime-art-qa.mjs",
    "qa:runtime-stability": "node scripts/runtime-stability-qa.mjs",
    "qa:publish-artboards": "node scripts/publish-artboards.mjs",
    "qa:asset-budget": "python3 scripts/asset-budget-report.py",
    "qa:background-continuity": "node scripts/background-continuity-qa.mjs",
    "qa:dpr-assets": "node scripts/dpr-asset-qa.mjs",
    "qa:input-hud": "node scripts/input-hud-regression-qa.mjs --phase after",
    "qa:home-layout": "node scripts/home-layout-qa.mjs --phase after",
    "qa:traversability": "node scripts/traversability-regression-qa.mjs --phase after",
    "qa:multitouch-pause": "node scripts/multitouch-pause-qa.mjs --phase after",
    "qa:projectile-readability": "node scripts/projectile-readability-qa.mjs",
    "qa:projectile-threat": "node scripts/projectile-threat-qa.mjs",
    "qa:tactical-traversal": "node scripts/tactical-traversal-qa.mjs --phase after",
    "qa:touch-crouch": "node scripts/touch-crouch-qa.mjs --phase after",
    "qa:world-contract": "node scripts/world-contract-regression-qa.mjs",
    "qa:escort-recovery": "node scripts/escort-encounter-recovery-qa.mjs",
    "qa:fullplay": "node scripts/full-play-input-qa.mjs --run-id current --no-video",
    "qa:stability:quick": "node scripts/runtime-stability-qa.mjs --soak-seconds 120 --restart-count 5 --report-name runtime-stability-polish-05.json",
    "qa:final-completion": "python3 scripts/final-completion-qa.py",
    "qa:player-fire-polish": "node scripts/player-fire-polish-qa.mjs",
    "qa:other-character-motion": "node scripts/other-character-motion-qa.mjs",
    "qa:combat-playtest": "node scripts/combat-playtest-qa.mjs",
    "qa:result-layout": "node scripts/result-layout-qa.mjs",
    "qa:continue-menu": "node scripts/continue-menu-qa.mjs",
    "qa:death-continue": "node scripts/death-continue-qa.mjs",
    "assets:detail-polish": "python3 scripts/normalize-detail-assets.py",
    "qa:detail-polish": "node scripts/detail-polish-qa.mjs",
    "qa:detail-round2": "node scripts/detail-round2-regression-qa.mjs",
    "qa:detail-round3": "node scripts/detail-round3-regression-qa.mjs",
    "qa:player-motion-continuity": "node scripts/player-motion-continuity-qa.mjs after",
    "qa:player-hit-crouch": "node scripts/player-hit-crouch-matrix-qa.mjs",
    "qa:player-runfire-crouch": "node scripts/player-runfire-crouch-transition-qa.mjs after",
    "qa:actor-floor-plane": "node scripts/actor-floor-plane-qa.mjs",
    "qa:destructible-clarity": "node scripts/destructible-visual-clarity-qa.mjs",
    "qa:grenade-distance": "node scripts/grenade-throw-distance-qa.mjs"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "vite": "^6.3.5"
  }
