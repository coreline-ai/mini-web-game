{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Game Feel VFX Manifest",
  "type": "object",
  "required": ["id", "type", "motion", "frames", "fps", "layout", "pivot", "loop"],
  "properties": {
    "id": { "type": "string" },
    "type": { "enum": ["vfx", "trail", "transition-mask", "ui-sequence"] },
    "motion": { "type": "string" },
    "frames": { "type": "integer", "minimum": 1 },
    "fps": { "type": "number", "exclusiveMinimum": 0 },
    "durationMs": { "type": "number", "minimum": 0 },
    "layout": {
      "type": "object",
      "required": ["columns", "rows", "frameWidth", "frameHeight", "margin", "gap", "paddingInsideFrame"],
      "properties": {
        "columns": { "type": "integer", "minimum": 1 },
        "rows": { "type": "integer", "minimum": 1 },
        "frameWidth": { "type": "integer", "minimum": 1 },
        "frameHeight": { "type": "integer", "minimum": 1 },
        "margin": { "type": "integer", "minimum": 0 },
        "gap": { "type": "integer", "minimum": 0 },
        "paddingInsideFrame": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "pivot": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "type": "number" }
    },
    "loop": { "type": "boolean" },
    "blendMode": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
